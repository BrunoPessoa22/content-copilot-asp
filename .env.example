# --- OKX seller -> Broker/Facilitator credentials (settle on X Layer) ---------
# From the OKX developer portal (web3.okx.com). Seller-side only — buyers never
# see these; the x402 payment is the only buyer-facing gate.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_BASE_URL=https://web3.okx.com

# --- Settlement ----------------------------------------------------------------
# X Layer wallet that receives USDT0 (0x779Ded... 6 decimals) per paid call.
PAY_TO_ADDRESS=
NETWORK=eip155:196
SYNC_SETTLE=true

# --- LLM backends (at least one required) ---------------------------------------
# Primary: private dispatch endpoint. Fallback: metered Anthropic API.
LLM_DISPATCH_URL=
LLM_DISPATCH_SECRET=
ANTHROPIC_API_KEY=
# CC_MODEL_FAST=claude-haiku-4-5-20251001
# CC_MODEL_QUALITY=claude-sonnet-5

# --- Pipeline --------------------------------------------------------------------
CC_SESSION_DIR=/data/sessions
# CC_WHISPER_MODEL=tiny
# CC_MAX_TRANSCRIBE_SECONDS=1500
# CC_YTDLP_PROXY=

# --- Ledger / alerting / admin ---------------------------------------------------
LEDGER_PATH=/data/ledger.db
ALERT_WEBHOOK_URL=
ADMIN_TOKEN=

# --- Server -----------------------------------------------------------------------
PORT=8788
PUBLIC_BASE_URL=https://copilot.brunopessoa.com
